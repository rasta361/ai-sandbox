# Project Configuration
PROJECT_NAME=project
PROJECT_PATH=.

# Sandbox Identity
SANDBOX_NAME=ai-sandbox

# User Identity (for git)
GIT_USER_NAME=AI Assistant
GIT_USER_EMAIL=ai@sandbox.local

# AI Tool Selection (claude, opencode, gemini, or pi)
AI_TOOL=claude

# Local model (LM Studio) — only used with the --local-model flag.
# Leave blank to auto-discover loaded models from LM Studio's /v1/models endpoint.
# Set to pin a specific model id (used as a fallback if discovery fails).
# LMSTUDIO_MODEL=qwen2.5-coder-7b-instruct

# Security
# DANGEROUSLY_SKIP_PERMISSIONS=true

# Audio Support
# PULSE_HOST_IP=192.168.1.100