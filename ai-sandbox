#!/bin/bash
set -e

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"

# Preserve original user's UID/GID and home when run with sudo
if [[ -n "$SUDO_UID" ]]; then
    HOST_UID="$SUDO_UID"
    HOST_GID="$SUDO_GID"
    HOST_HOME="$(getent passwd "$SUDO_UID" | cut -d: -f6)"
else
    HOST_UID="$(id -u)"
    HOST_GID="$(id -g)"
    HOST_HOME="$HOME"
fi

# Named volumes for credentials (persist across container restarts)
CLAUDE_VOLUME="ai-sandbox-claude-config"
OPENCODE_VOLUME="ai-sandbox-opencode-config"
GH_VOLUME="ai-sandbox-gh-config"

# Shared proxy configuration
PROXY_CONTAINER="ai-sandbox-proxy"
PROXY_NETWORK="ai-sandbox-proxy-net"

# Handle --stop-proxy command early
if [[ "$1" == "--stop-proxy" ]]; then
    echo "Stopping shared proxy..."
    docker rm -f "$PROXY_CONTAINER" 2>/dev/null && echo "Proxy container stopped." || echo "Proxy container not running."
    docker network rm "$PROXY_NETWORK" 2>/dev/null && echo "Proxy network removed." || echo "Proxy network not found or in use."
    exit 0
fi

# Initialize volumes with correct permissions if they're new
for volume in "$CLAUDE_VOLUME" "$OPENCODE_VOLUME" "$GH_VOLUME"; do
    if ! docker volume inspect "$volume" &>/dev/null; then
        echo "Creating config volume: $volume..."
        docker volume create "$volume" >/dev/null
    fi
done

# Ensure volumes have correct ownership for the current user
docker run --rm \
    -v "${CLAUDE_VOLUME}:/claude-config" \
    -v "${OPENCODE_VOLUME}:/opencode-config" \
    -v "${GH_VOLUME}:/gh-config" \
    alpine:latest \
    sh -c "chown -R ${HOST_UID}:${HOST_GID} /claude-config /opencode-config /gh-config" 2>/dev/null || true

# Parse arguments
SANDBOX_NAME="ai-sandbox"
NETWORK_UNRESTRICTED="false"
DANGEROUSLY_SKIP_PERMISSIONS="false"
PROJECT_PATH=""
AI_TOOL="claude"  # Default tool: claude or opencode

while [[ $# -gt 0 ]]; do
    case "$1" in
        --unrestricted)
            NETWORK_UNRESTRICTED="true"
            echo "Warning: Network unrestricted mode enabled"
            shift
            ;;
        --dangerously-skip-permissions)
            DANGEROUSLY_SKIP_PERMISSIONS="true"
            echo "Warning: Dangerously skipping permissions - AI tool will have unrestricted access"
            shift
            ;;
        -n|--name)
            if [[ -z "$2" || "$2" == -* ]]; then
                echo "Error: --name requires a value"
                exit 1
            fi
            SANDBOX_NAME="$2"
            shift 2
            ;;
        --opencode)
            AI_TOOL="opencode"
            shift
            ;;
        --claude)
            AI_TOOL="claude"
            shift
            ;;
        -*)
            echo "Unknown option: $1"
            exit 1
            ;;
        *)
            if [[ -z "$PROJECT_PATH" ]]; then
                PROJECT_PATH="$1"
            else
                echo "Error: Unexpected argument: $1"
                exit 1
            fi
            shift
            ;;
    esac
done

# Require project path argument
if [[ -z "$PROJECT_PATH" ]]; then
    echo "Usage: ai-sandbox /path/to/project [OPTIONS]"
    echo "       ai-sandbox --stop-proxy"
    echo ""
    echo "Options:"
    echo "  -n, --name NAME                    Instance name (allows multiple sandboxes)"
    echo "  --claude                           Use Claude Code (default)"
    echo "  --opencode                         Use OpenCode"
    echo "  --unrestricted                     Disable network allowlist (for research)"
    echo "  --dangerously-skip-permissions     Skip permission checks (DANGEROUS)"
    echo "  --stop-proxy                       Stop the shared proxy container"
    exit 1
fi

PROJECT_PATH="$(readlink -f "$PROJECT_PATH")"
if [[ ! -d "$PROJECT_PATH" ]]; then
    echo "Error: '$PROJECT_PATH' is not a directory"
    exit 1
fi

# Load environment variables from .env file
if [[ -f "$SCRIPT_DIR/.env" ]]; then
    set -a
    source "$SCRIPT_DIR/.env"
    set +a
fi

# Export variables for docker-compose
export HOST_UID HOST_GID
export PROJECT_PATH
export NETWORK_UNRESTRICTED
export DANGEROUSLY_SKIP_PERMISSIONS
export SANDBOX_NAME
export AI_TOOL
export GIT_USER_NAME="${GIT_USER_NAME:-}"
export GIT_USER_EMAIL="${GIT_USER_EMAIL:-}"

# Use COMPOSE_PROJECT_NAME for network isolation between instances
export COMPOSE_PROJECT_NAME="${SANDBOX_NAME}"

# Function to set terminal title
set_terminal_title() {
    local tool_upper=$(echo "$AI_TOOL" | tr '[:lower:]' '[:upper:]')
    echo -ne "\033]0;AI SANDBOX (${tool_upper}) - \"${SANDBOX_NAME}\" @ ${PROJECT_PATH}\007"
}

# Function to reset terminal title on exit
reset_terminal_title() {
    echo -ne "\033]0;\007"
}
trap reset_terminal_title EXIT

cd "$SCRIPT_DIR"

# Ensure shared proxy network exists (internal - sandboxes can only reach proxy)
if ! docker network inspect "$PROXY_NETWORK" &>/dev/null; then
    echo "Creating shared proxy network..."
    docker network create --internal "$PROXY_NETWORK" >/dev/null
fi

# Ensure shared proxy is running
if [[ "$(docker inspect -f '{{.State.Status}}' "$PROXY_CONTAINER" 2>/dev/null)" != "running" ]]; then
    echo "Starting shared proxy..."
    
    # Remove stale container if exists
    docker rm -f "$PROXY_CONTAINER" 2>/dev/null || true
    
    # Build proxy image only if it doesn't exist
    # Proxy starts on default bridge network (for internet access)
    if ! docker image inspect ai-sandbox-proxy-image &>/dev/null; then
        echo "Building proxy image..."
        docker build -q -t ai-sandbox-proxy-image "$SCRIPT_DIR/proxy" >/dev/null
    fi
    docker run -d \
        --name "$PROXY_CONTAINER" \
        -e "NETWORK_UNRESTRICTED=false" \
        -v "$SCRIPT_DIR/proxy/allowlist.txt:/etc/squid/allowlist.txt:ro" \
        --restart unless-stopped \
        ai-sandbox-proxy-image >/dev/null
    
    # Connect proxy to the internal sandbox network (so sandboxes can reach it)
    docker network connect "$PROXY_NETWORK" "$PROXY_CONTAINER"
    
    # Wait for proxy to be ready
    echo "Waiting for proxy to be ready..."
    for i in {1..30}; do
        if docker exec "$PROXY_CONTAINER" pgrep squid >/dev/null 2>&1; then
            break
        fi
        sleep 0.2
    done
else
    echo "Reusing existing proxy..."
fi

# Warn if unrestricted mode requested with shared proxy
if [[ "$NETWORK_UNRESTRICTED" == "true" ]]; then
    echo "Warning: --unrestricted ignored with shared proxy. Stop proxy first: docker rm -f $PROXY_CONTAINER"
fi

# Check if container is already running
if [[ "$(docker inspect -f '{{.State.Status}}' "${SANDBOX_NAME}" 2>/dev/null)" == "running" ]]; then
    echo "Attaching to existing sandbox '${SANDBOX_NAME}'..."
    set_terminal_title
    docker attach "${SANDBOX_NAME}"
    # Don't clean up - another terminal might have started this
    exit 0
fi

# Start sandbox container
docker compose up -d --build

# Wait for the sandbox container to be running
echo "Waiting for sandbox to start..."
while [[ "$(docker inspect -f '{{.State.Status}}' "${SANDBOX_NAME}" 2>/dev/null)" != "running" ]]; do
    sleep 0.2
done

# Set terminal title and attach
set_terminal_title
docker attach "${SANDBOX_NAME}"

# Clean up sandbox container only (keep shared proxy running)
docker compose down 2>/dev/null || true
