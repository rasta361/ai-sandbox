{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "edge-tts -t 'AI done' --write-media - | ffmpeg -loglevel quiet -i - -f s16le -ar 24000 -ac 1 - | paplay --raw --rate 24000 --channels 1"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(git push:*)",
      "Bash(git remote add:*)",
      "Bash(git remote set-url:*)",
      "Bash(git remote remove:*)",
      "Bash(git credential:*)",
      "Bash(gh api:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh release:*)",
      "Bash(gh repo:*)",
      "Bash(gh auth logout:*)",
      "Bash(gh config:*)",
      "Bash(gh gist:*)",
      "Bash(gh secret:*)",
      "Bash(gh variable:*)",
      "Bash(gh workflow:*)",
      "Bash(gh codespace:*)",
      "Bash(gh extension:*)"
    ]
  }
}
