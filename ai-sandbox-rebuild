#!/bin/bash
set -e

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
cd "$SCRIPT_DIR"

# Use same project name as ai-sandbox script for consistency
export COMPOSE_PROJECT_NAME="ai-sandbox"

# Set dummy values for compose validation (only building, not running)
export HOST_UID="$(id -u)"
export HOST_GID="$(id -g)"
export PROJECT_PATH="$SCRIPT_DIR"

echo "Building ai-sandbox image..."
docker compose build "$@"

echo ""
echo "Cleaning up old build cache and dangling images..."
docker builder prune -f --filter "until=24h" 2>/dev/null || true
docker image prune -f 2>/dev/null || true

echo ""
echo "Done. Run ./ai-sandbox /path/to/project to start."
